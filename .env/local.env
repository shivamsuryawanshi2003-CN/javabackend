# Template: copy to `local.env` (gitignored) and replace placeholders. Never commit real secrets.
# PowerShell (from backend/java):  . .\scripts\load-env.ps1
# Bash:                             source ./scripts/load-env.sh

# --- PostgreSQL (Docker: backend/java/docker-compose.yml maps 5432) ---
DB_URL=jdbc:postgresql://localhost:5432/authdb
DB_USERNAME=postgres
DB_PASSWORD=postgres
GATEWAY_DATASOURCE_URL=jdbc:postgresql://localhost:5432/authdb
GATEWAY_DATASOURCE_USERNAME=postgres
GATEWAY_DATASOURCE_PASSWORD=postgres

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
GATEWAY_REDIS_HOST=localhost
GATEWAY_REDIS_PORT=6379
# Leave empty if your Redis has no password (local Docker redis default)
GATEWAY_REDIS_PASSWORD=

# --- Kafka ---
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
REGISTRATION_TOPIC=notification.send

# --- JWT (must be identical for authservice + api-gateway; use a long random string in production) ---
JWT_SECRET=CHANGE_ME_USE_LONG_RANDOM_STRING_MIN_32_CHARS

JWT_ACCESS_TOKEN_EXPIRATION_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRATION_DAYS=7

# --- App (OAuth redirect target; Next.js dev server) ---
APP_FRONTEND_URL=http://localhost:3000

# --- OAuth: Google (Google Cloud Console → APIs & Services → Credentials) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- OAuth: GitHub (Developer Settings → OAuth Apps) ---
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- OAuth: Microsoft Entra (App registration; redirect URI: https://<gateway>/login/oauth2/code/azure) ---
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=

# --- OAuth: LinkedIn (OpenID; redirect URI: https://<gateway>/login/oauth2/code/linkedin) ---
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# --- Mail (SMTP; Gmail: enable 2-Step Verification → App passwords; MAIL_USERNAME = that Gmail address) ---
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# --- Internal APIs (subscription, role promotion) — send header X-Internal-Key ---
AUTH_INTERNAL_API_KEY=CHANGE_ME_STRONG_SECRET

# --- API Gateway ---
JOBRA_AUTH_SERVICE_URI=http://localhost:8081
# Browser origins allowed by the gateway (comma-separated; must include your Next.js origin)
GATEWAY_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
GATEWAY_AUDIT_ENABLED=true
GATEWAY_RATE_LIMIT_ENABLED=true
GATEWAY_RATE_LIMIT_FAIL_OPEN=true
GATEWAY_RL_DEFAULT=300

# --- Frontend (Next.js; used at build/runtime for API base URL) ---
NEXT_PUBLIC_GATEWAY_URL=http://localhost:8080
